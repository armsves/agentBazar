# Dynamic Configuration
# Get your environment ID from https://app.dynamic.xyz
NEXT_PUBLIC_DYNAMIC_ENV_ID=

# API token for server-side Dynamic operations (dashboard → API)
DYNAMIC_API_TOKEN=

# Webhook Secret — configure in Dynamic dashboard webhook settings
DYNAMIC_WEBHOOK_SECRET=

# RSA key for decrypting delegation shares from Dynamic webhooks.
# This is NOT an EVM wallet private key — it only decrypts delegated MPC shares
# that the user explicitly authorizes in the Dynamic frontend.
# Generate: openssl genrsa -out private-key.pem 3072
# Public key: openssl rsa -in private-key.pem -pubout -out public-key.pem
# Upload public key to Dynamic dashboard
DYNAMIC_DELEGATION_PRIVATE_KEY=

# LiFi Composer API (required for LP deposit flows)
LIFI_API_KEY=

# Optional Optimism RPC (defaults to https://mainnet.optimism.io)
# RPC_URL=https://mainnet.optimism.io

# Optional Composer API base URL (defaults to https://composer.li.quest)
# COMPOSER_BASE_URL=https://composer.li.quest

# Redis — local dev defaults to redis://localhost:6379
# KV_URL=redis://localhost:6379

# Vercel KV (production alternative to local Redis)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
