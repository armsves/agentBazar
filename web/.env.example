# Dynamic Configuration
# Get your environment ID from https://app.dynamic.xyz
NEXT_PUBLIC_DYNAMIC_ENV_ID=

# API token for server-side Dynamic operations (dashboard → API)
DYNAMIC_API_TOKEN=

# Webhook Secret — configure in Dynamic dashboard webhook settings
# Webhook URL (production): https://agent-bazar-eight.vercel.app/api/webhooks/dynamic
DYNAMIC_WEBHOOK_SECRET=

# RSA private key for decrypting delegation shares (multiline PEM in quotes).
# Upload matching public-key.pem to Dynamic: Embedded Wallets → Delegated Access
DYNAMIC_DELEGATION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"

# LiFi Composer API (required for LP deposit flows)
LIFI_API_KEY=

# Optional Optimism RPC (defaults to https://mainnet.optimism.io)
# RPC_URL=https://mainnet.optimism.io

# Optional Composer API base URL (defaults to https://composer.li.quest)
# COMPOSER_BASE_URL=https://composer.li.quest

# Vercel KV / Upstash — use the SAME remote store for local dev (do not use localhost Redis)
# Copy from Vercel → Storage → upstash-kv-ethglobalny2026 → .env.local tab
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional (REST above is enough for this app):
# KV_URL=
# REDIS_URL=

# Local dev checklist:
# 1. cp .env.example .env  (fill Dynamic + LiFi + KV_REST_* above)
# 2. npm run dev           (from web/) or npm run dev:web (from repo root)
# 3. curl http://localhost:3000/api/health/kv  → should show "ok":true
# 4. Dynamic dashboard CORS must include http://localhost:3000
# 5. For delegation webhooks locally, expose with ngrok and set webhook URL to:
#    https://<your-ngrok>.ngrok.io/api/webhooks/dynamic
