# LiFi Composer API (required for web app and optional CLI)
LIFI_API_KEY=

# --- Optional local CLI only — the web app does NOT use PRIVATE_KEY ---
# The web app signs via Dynamic delegation authorized in the frontend.
# PRIVATE_KEY=
# USDC_AMOUNT=1000000
# USDT_AMOUNT=1000000
# UNISWAP_VERSION=v3

# --- Web app env: copy web/.env.example → web/.env ---
# Dynamic + delegation RSA key + Redis. Upload web/../public-key.pem to Dynamic dashboard.
# Vercel: set the same DYNAMIC_DELEGATION_PRIVATE_KEY (full PEM) in project env vars.
